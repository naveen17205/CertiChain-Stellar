rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidCertificate(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.studentName is string && data.studentName.size() <= 200 &&
             data.courseName is string && data.courseName.size() <= 200 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.institutionName is string && data.institutionName.size() <= 200 &&
             data.stellarTxHash is string && data.stellarTxHash.size() <= 128 &&
             data.status in ['issued', 'revoked'];
    }

    match /certificates/{certificateId} {
      allow get: if true;
      allow list: if isSignedIn() && resource.data.institutionId == request.auth.uid;
      
      allow create: if isSignedIn() &&
                      isValidId(certificateId) &&
                      certificateId == incoming().id &&
                      incoming().institutionId == request.auth.uid &&
                      incoming().issueDate == request.time &&
                      isValidCertificate(incoming()) &&
                      exists(/databases/$(database)/documents/institutions/$(request.auth.uid));

      allow update: if isOwner(existing().institutionId) &&
                      incoming().id == existing().id &&
                      incoming().institutionId == existing().institutionId &&
                      incoming().stellarTxHash == existing().stellarTxHash &&
                      incoming().issueDate == existing().issueDate &&
                      isValidCertificate(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'studentName', 'courseName']);
    }

    function isValidInstitution(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200;
    }

    match /institutions/{institutionId} {
      allow get: if true;
      allow create: if isOwner(institutionId) &&
                      incoming().id == institutionId &&
                      isValidInstitution(incoming());
      allow update: if isOwner(institutionId) &&
                      incoming().id == existing().id &&
                      isValidInstitution(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'publicKey']);
    }
  }
}
